{
  "TEMP": {
    "name": "Tempo",
    "category": "Rhythm & Timing",
    "temporal_marker": "TEMPORAL PATTERN",
    "measures": "Speed of word/syllable production (linguistic density per unit of time)",
    "values": {
      "0": "Glacially slow, syllables stretched to breaking point",
      "1": "Unusually deliberate, excessive phoneme duration",
      "2": "Relaxed, unhurried pace (below conversational average)",
      "3": "Standard conversational tempo, balanced and natural",
      "4": "Brisk, elevated momentum with forward energy",
      "5": "Compressed, fast-flowing acoustic stream",
      "6": "Hyper-accelerated, blistering speed (auctioneer/panic)"
    }
  },
  "CHNK": {
    "name": "Chunking",
    "category": "Rhythm & Timing",
    "temporal_marker": "TEMPORAL PATTERN",
    "measures": "Breath units and pause frequency between groups",
    "values": {
      "0": "Severely fragmented, single syllables separated by silence",
      "1": "Very short choppy bursts (2-3 words), stop-and-go rhythm",
      "2": "Shorter than natural phrasing, cautious groupings",
      "3": "Natural sentence-sized clauses, organic breath cycles",
      "4": "Extended phrasing linking multiple sentences",
      "5": "Long dense streams with brief inhalations",
      "6": "Massive continuous wall with no pauses"
    }
  },
  "SMTH": {
